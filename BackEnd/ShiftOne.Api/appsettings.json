{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LoggingOptions": {
    "ApplicationName": "ShiftOne.Api",
    "CorrelationHeaderName": "X-Correlation-ID"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "Properties": {
      "ApplicationName": "ShiftOne.Api"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {ApplicationName} {EnvironmentName} {MachineName} {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/shiftone-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true,
          "flushToDiskInterval": "00:00:01",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {ApplicationName} {EnvironmentName} {MachineName} {CorrelationId} {RequestMethod} {RequestPath} {StatusCode} {ExecutionTimeMs}ms {ClientIp} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=Abdo;Database=ShiftOneDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=False"
  },
  "Database": {
    "RunMigrationsOnStartup": false,
    "SeedOnStartup": true
  },
  "SuperAdmin": {
    "Email": "admin@ShiftOne.com",
    "UserName": "admin@ShiftOne.com",
    "Password": "Aa@112233",
    "FirstName": "Super",
    "LastName": "Admin"
  },  "JwtSettings": {
    "SecretKey": "local-development-secret-key-for-ShiftOne-authentication",
    "Issuer": "ShiftOne.Local",
    "Audience": "ShiftOne.Local",
    "ExpiryMinutes": 15
  },
  "SmtpSettings": {
    "Host": "localhost",
    "Port": 587,
    "EnableSsl": false,
    "SenderEmail": "dev@ShiftOne.local",
    "SenderPassword": "dev-password"
  },
  "AllowedOrigins": "http://localhost:3000",
  "AllowedHosts": "*"
}
